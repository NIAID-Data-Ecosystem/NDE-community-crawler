# NDE Community Crawler — Credential Template
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── Reddit OAuth ──────────────────────────────────────────────────────────────
# Required for Reddit r/bioinformatics crawling.
# Setup: https://github.com/NIAID-Data-Ecosystem/NDE-community-crawler/blob/main/docs/setup.md#reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── Biostars API Key ──────────────────────────────────────────────────────────
# Required to bypass Cloudflare on Biostars.
# Get from: https://www.biostars.org/accounts/profile/ → API key section
BIOSTARS_API_KEY=

# ── Bioconductor Session Cookie (optional) ───────────────────────────────────
# If search endpoints remain inaccessible, add your session cookie value here.
# Get from browser DevTools → Application → Cookies → support.bioconductor.org
BIOCONDUCTOR_SESSION_COOKIE=
